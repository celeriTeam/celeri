{
  "expo": {
    "name": "Celeri",
    "slug": "celeri",
    "version": "8.2",
    "orientation": "portrait",
    "icon": "./assets/images/Lettuce.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.alp2goose.flex",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "CFBundleDisplayName": "Celeri"
      },
      "buildNumber": "8.2"
    },
    "android": {
      "googleServicesFile": "google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.alp2goose.flex",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      [
        "expo-font",
        {
          "fonts": [
            {
              "Lexend": "./assets/fonts/Lexend-Regular.ttf"
            }
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to let you set profile pictures.",
          "cameraPermission": "The app needs access to your camera to let you take profile pictures."
        }
      ],
      "react-native-health"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aced3ed5-7df5-4f2c-8f1c-dc12a8426cd8"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/aced3ed5-7df5-4f2c-8f1c-dc12a8426cd8"
    }
  }
}
