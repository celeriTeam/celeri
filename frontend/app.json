{
  "expo": {
    "name": "Celeri",
    "slug": "health-bets-app",
    "version": "8.9",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "health-bets-app",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.alp2goose.flex",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "NSMotionUsageDescription": "This app uses motion data to track your steps.",
        "NSHealthShareUsageDescription": "This app needs access to your health data to track your steps and health metrics.",
        "NSHealthUpdateUsageDescription": "This app needs access to your health data to update your health metrics.",
        "CFBundleDisplayName": "Celeri"
      },
      "buildNumber": "4"
    },
    "android": {
      "googleServicesFile": "google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.alp2goose.flex",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/Lettuce.jpg"
    },
    "plugins": [
      "./plugins/withCoreMotion",
      "expo-router",
      "expo-dev-client",
      "@react-native-firebase/app",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Lexend-Regular.ttf"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0",
            "useFrameworks": "static",
            "newArchEnabled": true
          },
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to let you set profile pictures.",
          "cameraPermission": "The app needs access to your camera to let you take profile pictures."
        }
      ],
      "react-native-health",
      [
        "expo-health-connect",
        {
          "permissions": [
            "android.permission.health.READ_STEPS",
            "android.permission.health.WRITE_STEPS"
          ]
        }
      ],
      "expo-asset",
      "sentry-expo",
      "react-native-health-connect"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aced3ed5-7df5-4f2c-8f1c-dc12a8426cd8"
      }
    },
    "runtimeVersion": "2.0.2",
    "updates": {
      "url": "https://u.expo.dev/aced3ed5-7df5-4f2c-8f1c-dc12a8426cd8"
    }
  }
}
