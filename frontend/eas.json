{
  "cli": {
    "version": ">= 10.2.2"
  },
  "build": {
    "internal": {
      "distribution": "internal",
      "ios": {
        "enterpriseProvisioning": "adhoc"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {}
    },
    "production": {
      "ios": {
        "hooks": {
          "postinstall": "patch-package"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
